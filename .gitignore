# ─── Dependencies ───
node_modules/

# ─── Environment & Secrets (CRITICAL) ───
.env
.env.*
!.env.example

# ─── Claude Code local settings (may contain secrets) ───
.claude/settings.local.json
\#\ Core\ Settings.ini
google-service-account.json
monobank_cache.json

# ─── Session & Auth files ───
*.session

# ─── Build output ───
/dist/
/src/generated/prisma/

# ─── Compiled TypeScript artifacts ───
*.d.ts
!src/**/*.d.ts
*.d.ts.map
*.js.map
# Root-level compiled JS (keep eslint.config.js, vitest.config.js)
/check_*.js
/find_*.js
/verify_*.js
/np-*.js
prisma/seed.js
prisma/seed.d.ts
scripts/assign-roles.js
scripts/assign-roles.d.ts

# ─── Databases ───
/db/
prisma/db/
prisma/dev.db
*.db
*.db-shm
*.db-wal

# ─── Logs ───
logs/
*.log

# ─── Sensitive data files ───
members.txt
migration.sql

# ─── Server config ───
*.exp
pg_hba*.conf

# ─── Backups ───
backups/

# ─── OS artifacts ───
.DS_Store
Thumbs.db

# ─── Test artifacts ───
canvas-test.png

